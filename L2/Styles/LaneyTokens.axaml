<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Default">
      <SolidColorBrush x:Key="LaneySurfaceRootBrush" Color="#FAF6FAFE"/>
      <SolidColorBrush x:Key="LaneySurfaceSidebarBrush" Color="#F2FFFFFF"/>
      <SolidColorBrush x:Key="LaneySurfacePanelBrush" Color="#F0FFFFFF"/>
      <SolidColorBrush x:Key="LaneySurfaceRaisedBrush" Color="#F7FFFFFF"/>
      <SolidColorBrush x:Key="LaneySurfaceOverlayBrush" Color="#FFFFFFFF"/>
      <SolidColorBrush x:Key="LaneyMutedSurfaceBrush" Color="#BFEAF0F7"/>
      <SolidColorBrush x:Key="LaneyFieldBackgroundBrush" Color="#BFFFFFFF"/>
      <SolidColorBrush x:Key="LaneyFieldHoverBrush" Color="#E8FFFFFF"/>
      <SolidColorBrush x:Key="LaneyFieldBorderBrush" Color="#8FB7C5D6"/>
      <SolidColorBrush x:Key="LaneyChatListHoverBrush" Color="#66DCEEFF"/>
      <SolidColorBrush x:Key="LaneyChatListSelectedBrush" Color="#99CFE8FF"/>
      <SolidColorBrush x:Key="LaneySkeletonBrush" Color="#BFE3EAF2"/>

      <SolidColorBrush x:Key="LaneyBorderSubtleBrush" Color="#7FB8C5D2"/>
      <SolidColorBrush x:Key="LaneyBorderStrongBrush" Color="#A78EA0B4"/>
      <SolidColorBrush x:Key="LaneyGlassPanelBrush" Color="#E3FFFFFF"/>
      <SolidColorBrush x:Key="LaneyGlassRaisedBrush" Color="#EEFFFFFF"/>
      <SolidColorBrush x:Key="LaneyGlassOverlayBrush" Color="#F8FFFFFF"/>
      <SolidColorBrush x:Key="LaneyGlassBorderBrush" Color="#78A9BCD0"/>
      <SolidColorBrush x:Key="LaneyGlassHighlightBrush" Color="#C8FFFFFF"/>
      <SolidColorBrush x:Key="LaneyGlassShadowBrush" Color="#0D1D2B3A"/>

      <SolidColorBrush x:Key="LaneyTextMutedBrush" Color="#657386"/>
      <SolidColorBrush x:Key="LaneyTextSubtleBrush" Color="#8A96A6"/>
      <SolidColorBrush x:Key="LaneyTextInvertedBrush" Color="#FFFFFF"/>

      <SolidColorBrush x:Key="LaneyAccentBrush" Color="#3390EC"/>
      <SolidColorBrush x:Key="LaneyAccentSoftBrush" Color="#D9ECFF"/>
      <SolidColorBrush x:Key="LaneyAccentTextBrush" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="LaneyFocusRingBrush" Color="#3390EC" Opacity="0.42"/>

      <SolidColorBrush x:Key="LaneyDangerBrush" Color="#E5484D"/>
      <SolidColorBrush x:Key="LaneyDangerSoftBrush" Color="#FFE5E7"/>
      <SolidColorBrush x:Key="LaneySuccessBrush" Color="#1FAD66"/>
      <SolidColorBrush x:Key="LaneySuccessSoftBrush" Color="#DDF8E8"/>
      <SolidColorBrush x:Key="LaneyWarningBrush" Color="#C88719"/>
      <SolidColorBrush x:Key="LaneyWarningSoftBrush" Color="#FFF2D6"/>

      <SolidColorBrush x:Key="LaneyScrimBrush" Color="#0D1117" Opacity="0.42"/>
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="LaneySurfaceRootBrush" Color="#FF070B10"/>
      <SolidColorBrush x:Key="LaneySurfaceSidebarBrush" Color="#FA0B1118"/>
      <SolidColorBrush x:Key="LaneySurfacePanelBrush" Color="#F6101720"/>
      <SolidColorBrush x:Key="LaneySurfaceRaisedBrush" Color="#FA17212C"/>
      <SolidColorBrush x:Key="LaneySurfaceOverlayBrush" Color="#FF1C2735"/>
      <SolidColorBrush x:Key="LaneyMutedSurfaceBrush" Color="#7A202A36"/>
      <SolidColorBrush x:Key="LaneyFieldBackgroundBrush" Color="#CC172331"/>
      <SolidColorBrush x:Key="LaneyFieldHoverBrush" Color="#E01C2A3A"/>
      <SolidColorBrush x:Key="LaneyFieldBorderBrush" Color="#42A9C7EC"/>
      <SolidColorBrush x:Key="LaneyChatListHoverBrush" Color="#332B67A0"/>
      <SolidColorBrush x:Key="LaneyChatListSelectedBrush" Color="#703390EC"/>
      <SolidColorBrush x:Key="LaneySkeletonBrush" Color="#B02A3341"/>

      <SolidColorBrush x:Key="LaneyBorderSubtleBrush" Color="#29FFFFFF"/>
      <SolidColorBrush x:Key="LaneyBorderStrongBrush" Color="#44FFFFFF"/>
      <SolidColorBrush x:Key="LaneyGlassPanelBrush" Color="#BE0B121B"/>
      <SolidColorBrush x:Key="LaneyGlassRaisedBrush" Color="#D1182533"/>
      <SolidColorBrush x:Key="LaneyGlassOverlayBrush" Color="#E3223040"/>
      <SolidColorBrush x:Key="LaneyGlassBorderBrush" Color="#3E93BCEB"/>
      <SolidColorBrush x:Key="LaneyGlassHighlightBrush" Color="#35FFFFFF"/>
      <SolidColorBrush x:Key="LaneyGlassShadowBrush" Color="#1A000000"/>

      <SolidColorBrush x:Key="LaneyTextMutedBrush" Color="#8B97A8"/>
      <SolidColorBrush x:Key="LaneyTextSubtleBrush" Color="#667386"/>
      <SolidColorBrush x:Key="LaneyTextInvertedBrush" Color="#FFFFFF"/>

      <SolidColorBrush x:Key="LaneyAccentBrush" Color="#4A9EFF"/>
      <SolidColorBrush x:Key="LaneyAccentSoftBrush" Color="#17304A"/>
      <SolidColorBrush x:Key="LaneyAccentTextBrush" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="LaneyFocusRingBrush" Color="#4A9EFF" Opacity="0.48"/>

      <SolidColorBrush x:Key="LaneyDangerBrush" Color="#FF5C66"/>
      <SolidColorBrush x:Key="LaneyDangerSoftBrush" Color="#3A1D24"/>
      <SolidColorBrush x:Key="LaneySuccessBrush" Color="#35C979"/>
      <SolidColorBrush x:Key="LaneySuccessSoftBrush" Color="#153523"/>
      <SolidColorBrush x:Key="LaneyWarningBrush" Color="#E6A23C"/>
      <SolidColorBrush x:Key="LaneyWarningSoftBrush" Color="#3A2B13"/>

      <SolidColorBrush x:Key="LaneyScrimBrush" Color="#000000" Opacity="0.58"/>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <StaticResource x:Key="LaneySurface" ResourceKey="LaneySurfacePanelBrush"/>
  <StaticResource x:Key="LaneySurfaceMuted" ResourceKey="LaneyMutedSurfaceBrush"/>
  <StaticResource x:Key="LaneySurfaceRaised" ResourceKey="LaneySurfaceRaisedBrush"/>
  <StaticResource x:Key="LaneyFieldBackground" ResourceKey="LaneyFieldBackgroundBrush"/>
  <StaticResource x:Key="LaneyFieldBorder" ResourceKey="LaneyFieldBorderBrush"/>
  <StaticResource x:Key="LaneyBorderSubtle" ResourceKey="LaneyBorderSubtleBrush"/>
  <StaticResource x:Key="LaneyGlassPanel" ResourceKey="LaneyGlassPanelBrush"/>
  <StaticResource x:Key="LaneyGlassRaised" ResourceKey="LaneyGlassRaisedBrush"/>
  <StaticResource x:Key="LaneyGlassBorder" ResourceKey="LaneyGlassBorderBrush"/>
  <StaticResource x:Key="LaneyTextMuted" ResourceKey="LaneyTextMutedBrush"/>
  <StaticResource x:Key="LaneyAccent" ResourceKey="LaneyAccentBrush"/>
  <StaticResource x:Key="LaneyDanger" ResourceKey="LaneyDangerBrush"/>
  <StaticResource x:Key="LaneySuccess" ResourceKey="LaneySuccessBrush"/>

  <CornerRadius x:Key="LaneyRadius4">4</CornerRadius>
  <CornerRadius x:Key="LaneyRadius8">8</CornerRadius>
  <CornerRadius x:Key="LaneyRadius12">12</CornerRadius>
  <CornerRadius x:Key="LaneyRadius16">16</CornerRadius>

  <x:Double x:Key="LaneySpace4">4</x:Double>
  <x:Double x:Key="LaneySpace8">8</x:Double>
  <x:Double x:Key="LaneySpace12">12</x:Double>
  <x:Double x:Key="LaneySpace16">16</x:Double>
  <x:Double x:Key="LaneySpace24">24</x:Double>
</ResourceDictionary>

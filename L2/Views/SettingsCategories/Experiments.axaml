<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vkui="using:VKUI.Controls"
             xmlns:vm="using:ELOR.Laney.ViewModels.SettingsCategories"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ELOR.Laney.Views.SettingsCategories.Experiments" x:DataType="vm:ExperimentsViewModel">
  <ScrollViewer>
    <StackPanel>
      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Флаги функций"/>
          </Grid>
          <ItemsControl ItemsSource="{Binding FeatureFlags}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:FeatureFlagOption">
                <vkui:Cell Header="{Binding Title}" Subtitle="{Binding Subtitle}">
                  <vkui:Cell.After>
                    <ToggleSwitch IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
                  </vkui:Cell.After>
                </vkui:Cell>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Режимы"/>
          </Grid>
          <vkui:Cell Header="Режим стримера" Subtitle="Маскировать чувствительные данные на экране.">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding StreamerMode, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Dev-пункты в меню" Subtitle="Показывать отладочные команды в контекстных меню.">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding ShowDevItemsInContextMenus, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Не отмечать прочитанным" Subtitle="Debug-переключатель поведения чтения.">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding DisableMarkingMessagesAsRead, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>

      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Оверлеи"/>
          </Grid>
          <vkui:Cell Header="FPS">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding ShowFPS, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Счетчики чата">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding ShowDebugCounters, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Debug в галерее">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding ShowDebugInfoInGallery, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>

      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Логи"/>
          </Grid>
          <vkui:Cell Header="Логи ядра">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding EnableLogs, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Логи BitmapManager">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding BitmapManagerLogs, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Логи рендера сообщений">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding MessageRenderingLogs, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>

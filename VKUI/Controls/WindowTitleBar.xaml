<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:chr="using:Avalonia.Controls.Chrome"
        xmlns:vkui="using:VKUI.Controls">
  <Design.PreviewWith>
    <vkui:WindowTitleBar Width="360"/>
  </Design.PreviewWith>

  <ControlTheme x:Key="{x:Type chr:WindowDrawnDecorations}" TargetType="chr:WindowDrawnDecorations">
	<Setter Property="DefaultTitleBarHeight" Value="0"/>
  </ControlTheme>

  <ControlTheme x:Key="{x:Type vkui:WindowTitleBar}" TargetType="vkui:WindowTitleBar">
    <Setter Property="CanShowTitle" Value="True"/>
    <Setter Property="CanMove" Value="True"/>
    <Setter Property="VerticalAlignment" Value="Top"/>
    <Setter Property="Template">
      <ControlTemplate>
        <Grid x:Name="TitleBar" ColumnDefinitions="* Auto Auto Auto">
          <TextBlock x:Name="WindowTitle" Grid.ColumnSpan="4" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
          <Border x:Name="DragArea" Grid.ColumnSpan="4" Background="Transparent"/>
          <Button x:Name="MinimizeButton" Grid.Column="1" IsVisible="False"
                  Width="24" Height="24" MinHeight="24" CornerRadius="12" Margin="4,12,0,12" Padding="0">
            <TextBlock Text="_" Margin="0,-8,0,0" Foreground="{DynamicResource VKIconOutlineMediumBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
          <Button x:Name="MaximizeButton" Grid.Column="2" IsVisible="False"
                  Width="24" Height="24" MinHeight="24" CornerRadius="12" Margin="4,12,0,12" Padding="0">
            <TextBlock x:Name="MaximizeIcon" Text="□" Foreground="{DynamicResource VKIconOutlineMediumBrush}" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Button>
          <Button x:Name="CloseButton" Grid.Column="3" IsVisible="False" IsCancel="True"
                  Width="24" Height="24" MinHeight="24" CornerRadius="12" Margin="4,12,12,12" Padding="4">
            <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon16Cancel}" Foreground="{DynamicResource VKIconOutlineMediumBrush}"/>
          </Button>
        </Grid>
      </ControlTemplate>
    </Setter>

    <Style Selector="^ /template/ TextBlock.Mac">
      <Setter Property="Margin" Value="68,5,68,4"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="LineHeight" Value="18"/>
      <Setter Property="Foreground" Value="{DynamicResource VKTextSubheadBrush}"/>
    </Style>
    <Style Selector="^ /template/ TextBlock.Default">
      <Setter Property="Margin" Value="32,15"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="LineHeight" Value="18"/>
    </Style>
  </ControlTheme>
</ResourceDictionary>

<vkw:DialogWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i18n="using:ELOR.Laney.Assets.i18n"
        xmlns:controls="using:ELOR.Laney.Controls"
        xmlns:mdl="using:ELOR.Laney.DataModels"
        xmlns:vkw="using:VKUI.Windows"
        xmlns:vkui="using:VKUI.Controls"
        xmlns:vm="using:ELOR.Laney.ViewModels"
        mc:Ignorable="d" d:DesignWidth="920" d:DesignHeight="700"
        x:Class="ELOR.Laney.Views.SettingsWindow" x:DataType="vm:SettingsViewModel"
        Width="920" Height="700"
        WindowDecorations="None"
        Background="{DynamicResource LaneySurfaceRootBrush}"
        Title="{x:Static i18n:Resources.settings}">
  <vkw:DialogWindow.Resources>
    <DataTemplate x:Key="SettingsSearchResultTemplate" x:DataType="mdl:SettingsSearchResult">
      <Grid MinHeight="52" Margin="12,6" ColumnDefinitions="Auto *" Background="Transparent">
        <vkui:VKIcon Width="28" Height="28" Margin="0,2,12,0" VerticalAlignment="Top" Foreground="{DynamicResource VKIconSecondaryBrush}" Id="{Binding IconId}"/>
        <StackPanel Grid.Column="1">
          <TextBlock Classes="Subhead" FontWeight="Medium" Foreground="{DynamicResource VKTextPrimaryBrush}" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
          <TextBlock Classes="Caption1" Foreground="{DynamicResource VKTextSecondaryBrush}" Text="{Binding CategoryTitle}" TextTrimming="CharacterEllipsis"/>
          <TextBlock Classes="Caption1" Foreground="{DynamicResource VKTextSubheadBrush}" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis" IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
        </StackPanel>
      </Grid>
    </DataTemplate>
  </vkw:DialogWindow.Resources>

  <Border BorderBrush="{DynamicResource LaneyGlassBorderBrush}" BorderThickness="1" Background="{DynamicResource LaneySurfaceRootBrush}">
  <Grid RowDefinitions="Auto Auto *" ColumnDefinitions="264 *">
    <Grid Grid.Row="1" Margin="12,0,8,8">
      <TextBox x:Name="SettingsSearchBox" Classes="Search" Text="{Binding SearchQuery, Mode=TwoWay}"/>
    </Grid>

    <Grid x:Name="CategoriesPanel" Grid.Row="2" Background="{DynamicResource LaneyGlassPanelBrush}">
      <Grid.Styles>
        <Style Selector="ListBoxItem">
          <Setter Property="Padding" Value="0"/>
        </Style>
      </Grid.Styles>
      <ListBox x:Name="CategoriesList" Margin="8,0,0,0" IsVisible="{Binding !IsSearchActive}" ItemTemplate="{StaticResource CellItemTemplate}" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory, Mode=TwoWay}" SelectionMode="Toggle" SelectionChanged="CategoriesList_SelectionChanged"/>

      <Grid IsVisible="{Binding IsSearchActive}">
        <ListBox x:Name="SearchResultsList" Margin="8,0,0,0" IsVisible="{Binding HasSearchResults}" ItemTemplate="{StaticResource SettingsSearchResultTemplate}" ItemsSource="{Binding SearchResults}" SelectionMode="Single" SelectionChanged="SearchResultsList_SelectionChanged"/>

        <vkui:Placeholder x:Name="NoSearchResultsPlaceholder" Classes="Compact" IsVisible="{Binding ShowNoSearchResults}" VerticalAlignment="Center">
          <vkui:Placeholder.Icon>
            <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon28SearchOutline}"/>
          </vkui:Placeholder.Icon>
        </vkui:Placeholder>
      </Grid>
    </Grid>
    <ContentControl x:Name="ContentPanel" Grid.Column="1" Grid.Row="2">
      <ContentControl.Styles>
        <Style Selector="vkui|Cell">
          <Setter Property="AutoBeforeIcon" Value="True"/>
        </Style>

        <Style Selector="vkui|Cell /template/ ContentPresenter#AfterControl > ToggleSwitch">
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="Margin" Value="-2,0,-2,0"/>
        </Style>

        <Style Selector="vkui|Cell /template/ ContentPresenter#AfterControl > ComboBox.Alternate">
          <Setter Property="VerticalAlignment" Value="Center"/>
          <Setter Property="Margin" Value="0"/>
          <Setter Property="Foreground" Value="{DynamicResource VKTextLinkBrush}"/>
        </Style>

        <Style Selector="Border.Group vkui|Cell:nth-child(1)">
          <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style Selector="Border.Group vkui|Cell:nth-last-child(1)">
          <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style Selector="Border.Group > StackPanel > Button.Tertiary:nth-child(1)">
          <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style Selector="Border.Group > StackPanel > Button.Tertiary:nth-last-child(1)">
          <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style Selector="Border.Group > StackPanel > Button.Tertiary:nth-child(1), Border.Group > StackPanel > Button.Tertiary:nth-last-child(1)">
          <Setter Property="Margin" Value="0,6"/>
        </Style>

        <Style Selector="Border.Group > StackPanel > Button.Tertiary">
          <Setter Property="Foreground" Value="{DynamicResource VKTextPrimaryBrush}"/>
          <Setter Property="FontWeight" Value="Regular"/>
          <Setter Property="Padding" Value="0,0,0,0"/>
          <Setter Property="HorizontalAlignment" Value="Stretch"/>
          <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
      </ContentControl.Styles>
    </ContentControl>

    <!-- <Rectangle x:Name="Separator" Grid.RowSpan="2" HorizontalAlignment="Right" Width="1" VerticalAlignment="Stretch" Fill="{DynamicResource VKSeparatorAlphaBrush}"/> -->
    <Rectangle x:Name="SearchBoxTopMarginForLinux" Height="12"/>
    <vkui:WindowTitleBar x:Name="TitleBar" Grid.ColumnSpan="2" CanShowTitle="True" CanMove="True"/>
  </Grid>
  </Border>
</vkw:DialogWindow>

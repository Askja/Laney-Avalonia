<vkui:Page xmlns="https://github.com/avaloniaui"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:vkui="using:VKUI.Controls"
           xmlns:i18n="using:ELOR.Laney.Assets.i18n"
           mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="540"
           x:Class="ELOR.Laney.Views.SignIn.DirectAuthPage">
  <Grid RowDefinitions="Auto *">
    <Image HorizontalAlignment="Center" Width="28" Height="28" Margin="0,12" Source="{StaticResource Logo}"/>
    <vkui:PanelHeader IsSeparatorVisible="False">
      <vkui:PanelHeader.LeftButtons>
        <Button x:Name="BackButton" Click="BackButton_Click">
          <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon28ArrowLeftOutline}"/>
        </Button>
      </vkui:PanelHeader.LeftButtons>
    </vkui:PanelHeader>

    <StackPanel Grid.Row="1" Margin="24,12" Spacing="12">
      <TextBlock Classes="Title2" FontWeight="Medium" TextAlignment="Center" Text="{x:Static i18n:Resources.sign_in_direct}"/>
      <TextBox x:Name="LoginBox" PlaceholderText="{x:Static i18n:Resources.da_login}"/>
      <TextBox x:Name="PasswordBox" PlaceholderText="{x:Static i18n:Resources.da_password}" PasswordChar="*"/>
      <TextBlock x:Name="ErrorText" Classes="Caption1" Foreground="{DynamicResource VKTextNegativeBrush}" TextWrapping="Wrap" IsVisible="False"/>
      <Button x:Name="SignInButton" Classes="Large Primary" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="0" Click="SignInButton_Click">
        <Grid ColumnDefinitions="44 * 44">
          <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon28UserOutgoingOutline}" Foreground="{DynamicResource VKButtonPrimaryForegroundBrush}" Margin="8"/>
          <TextBlock Grid.Column="1" Classes="Headline" FontWeight="Medium" TextAlignment="Center" VerticalAlignment="Center" Text="{x:Static i18n:Resources.sign_in}"/>
        </Grid>
      </Button>
      <vkui:Spinner x:Name="Loading" Width="44" Height="44" Margin="0,16,0,0" HorizontalAlignment="Center" IsVisible="False"/>
    </StackPanel>
  </Grid>
</vkui:Page>

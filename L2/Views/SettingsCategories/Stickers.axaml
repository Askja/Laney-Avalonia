<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vkui="using:VKUI.Controls"
             xmlns:controls="using:ELOR.Laney.Controls"
             xmlns:vm="using:ELOR.Laney.ViewModels.SettingsCategories"
             xmlns:mdl="using:ELOR.Laney.DataModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ELOR.Laney.Views.SettingsCategories.Stickers" x:DataType="vm:StickersViewModel">
  <ScrollViewer>
    <StackPanel>
      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Подсказки и анимация"/>
          </Grid>
          <vkui:Cell Header="Подсказывать стикеры" Subtitle="VK и локальные стикеры по тексту в поле ввода.">
            <vkui:Cell.After>
              <ToggleSwitch IsChecked="{Binding SuggestStickers, Mode=TwoWay}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Анимация стикеров" Subtitle="Полезно для экономии ОЗУ и CPU на слабом железе.">
            <vkui:Cell.After>
              <ComboBox Classes="Alternate" ItemsSource="{Binding StickerAnimationModes}" SelectedItem="{Binding CurrentStickerAnimationMode, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="mdl:TwoStringTuple">
                    <TextBlock Text="{Binding Item2}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>

      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Эмодзи-паки"/>
          </Grid>
          <vkui:Cell Header="Набор emoji" Subtitle="Глобальный порядок и состав emoji в picker. Для отдельных чатов можно переопределить в профиле чата.">
            <vkui:Cell.After>
              <ComboBox Classes="Alternate" Width="190" ItemsSource="{Binding EmojiPackOptions}" SelectedItem="{Binding CurrentEmojiPack, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="mdl:TwoStringTuple">
                    <TextBlock Text="{Binding Item2}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Кастомный emoji manifest" Subtitle="Файл со списком emoji или sprite-пака: emoji=path/to/image.png.">
            <vkui:Cell.After>
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Width="280" Classes="Subhead" Foreground="{DynamicResource VKTextSecondaryBrush}" Text="{Binding EmojiCustomPackPathSummary}" TextTrimming="CharacterEllipsis"/>
                <Button Classes="Secondary" Click="EmojiCustomPackBrowse_Click">
                  <TextBlock Text="Выбрать"/>
                </Button>
              </StackPanel>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Активный режим" Subtitle="Если custom-файл пустой или битый, picker не падает, а берет системный пак.">
            <vkui:Cell.After>
              <TextBlock Classes="Subhead" Text="{Binding EmojiPackSummary}" Foreground="{DynamicResource VKTextSecondaryBrush}"/>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>

      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Локальная библиотека"/>
          </Grid>
          <vkui:Cell Header="Импортированные стикеры" Subtitle="Telegram/WebP/WebM/TGS паки лежат локально и доступны в панели стикеров.">
            <vkui:Cell.After>
              <TextBlock Classes="Subhead" Text="{Binding LocalStickerCountText}" Foreground="{DynamicResource VKTextSecondaryBrush}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Импорт Telegram/локальных" Subtitle="Файлы, zip или официальный импорт TG-пака по ссылке через Bot API token.">
            <vkui:Cell.After>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="Tertiary" Click="ImportLocalStickerFiles_Click">
                  <TextBlock Text="Файлы"/>
                </Button>
                <Button Classes="Tertiary" Click="ImportTelegramPackLink_Click">
                  <TextBlock Text="Ссылка Telegram"/>
                </Button>
              </StackPanel>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Отправка локальных" Subtitle="Авто: растровые как граффити, анимации и неподходящие форматы как файл.">
            <vkui:Cell.After>
              <ComboBox Classes="Alternate" Width="190" ItemsSource="{Binding LocalStickerSendModeOptions}" SelectedItem="{Binding CurrentLocalStickerSendMode, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="mdl:TwoStringTuple">
                    <TextBlock Text="{Binding Item2}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </vkui:Cell.After>
          </vkui:Cell>
          <vkui:Cell Header="Управление паками" Subtitle="Отключение, порядок, избранное и теги локальной библиотеки.">
            <vkui:Cell.After>
              <TextBlock Classes="Subhead" Text="{Binding LocalStickerManagerSummary}" Foreground="{DynamicResource VKTextSecondaryBrush}"/>
            </vkui:Cell.After>
          </vkui:Cell>
          <ItemsControl ItemsSource="{Binding LocalStickerPacks}" Margin="12,4,12,8">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:LocalStickerPackItemViewModel">
                <Grid ColumnDefinitions="* Auto Auto Auto" ColumnSpacing="8" Margin="0,4">
                  <StackPanel Spacing="2">
                    <TextBlock Classes="Subhead" FontWeight="Medium" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Classes="Caption1" Foreground="{DynamicResource VKTextSecondaryBrush}" Text="{Binding Subtitle}" TextTrimming="CharacterEllipsis"/>
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1" IsChecked="{Binding IsEnabled}" Click="LocalStickerPackEnabled_Click"/>
                  <Button Grid.Column="2" Classes="Tertiary" Width="32" Height="32" Padding="0" Click="LocalStickerPackUp_Click">
                    <TextBlock Text="↑"/>
                  </Button>
                  <Button Grid.Column="3" Classes="Tertiary" Width="32" Height="32" Padding="0" Click="LocalStickerPackDown_Click">
                    <TextBlock Text="↓"/>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBox Classes="Transparent" Margin="12,0,12,8" PlaceholderText="Поиск и теги локальных стикеров" Text="{Binding LocalStickerManagerQuery, Mode=TwoWay}"/>
          <ItemsControl ItemsSource="{Binding LocalStickerItems}" Margin="12,0,12,12">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:LocalStickerItemViewModel">
                <Grid ColumnDefinitions="48 * Auto Auto" ColumnSpacing="8" Margin="0,4">
                  <Grid Width="44" Height="44">
                    <Image Width="40" Height="40" IsVisible="{Binding Sticker.CanPreview}" controls:ImageLoader.Source="{Binding Sticker.PreviewUri}"/>
                    <Border Width="40" Height="40" CornerRadius="8" Background="{DynamicResource VKImBubbleIncomingBrush}" IsVisible="{Binding !Sticker.CanPreview}">
                      <TextBlock Classes="Caption2" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding Sticker.DisplayKind}"/>
                    </Border>
                  </Grid>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="Subhead" Text="{Binding Title}" TextTrimming="CharacterEllipsis"/>
                    <TextBox Classes="Transparent" Text="{Binding Tags, Mode=TwoWay}" PlaceholderText="теги через пробел"/>
                  </StackPanel>
                  <Button Grid.Column="2" Classes="Tertiary" Width="36" Height="36" Padding="0" Click="LocalStickerFavorite_Click">
                    <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon20FavoriteOutline}"/>
                  </Button>
                  <Button Grid.Column="3" Classes="Tertiary" Width="36" Height="36" Padding="0" Click="LocalStickerTagsSave_Click">
                    <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon20Check}"/>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vkui="using:VKUI.Controls"
             xmlns:i18n="using:ELOR.Laney.Assets.i18n"
             xmlns:vm="using:ELOR.Laney.ViewModels.SettingsCategories"
             xmlns:mdl="using:ELOR.Laney.DataModels"
             mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="450"
             x:Class="ELOR.Laney.Views.SettingsCategories.General" x:DataType="vm:GeneralViewModel">
  <ScrollViewer>
    <StackPanel>
      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <vkui:Cell Margin="0" Header="{x:Static i18n:Resources.st_lang}">
            <vkui:Cell.After>
              <ComboBox Classes="Alternate" ItemsSource="{Binding Languages}" SelectedItem="{Binding CurrentLanguage, Mode=TwoWay}" SelectionChanged="ComboBox_SelectionChanged">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="mdl:TwoStringTuple">
                    <TextBlock Text="{Binding Item2}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>
      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Профиль интерфейса"/>
          </Grid>
          <vkui:Cell Header="Пресет" Subtitle="Быстрые наборы настроек под работу, ночь, слабое железо и стрим.">
            <vkui:Cell.After>
              <StackPanel Orientation="Horizontal">
                <Border Classes="LaneyOnlyBadge" Margin="0,0,8,0">
                  <TextBlock Text="{x:Static i18n:Resources.laney_only_badge}"/>
                </Border>
                <ComboBox Classes="Alternate" ItemsSource="{Binding InterfaceProfiles}" SelectedItem="{Binding CurrentInterfaceProfile, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="mdl:TwoStringTuple">
                      <TextBlock Text="{Binding Item2}"/>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
            </vkui:Cell.After>
          </vkui:Cell>
        </StackPanel>
      </Border>
      <Border Classes="Group" VerticalAlignment="Top">
        <StackPanel>
          <Grid Classes="GroupHeader">
            <TextBlock Text="Backup настроек"/>
          </Grid>
          <vkui:Cell Header="Режим данных" Subtitle="{Binding LocalDataMode}">
            <vkui:Cell.Before>
              <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon24DoneOutline}"/>
            </vkui:Cell.Before>
          </vkui:Cell>
          <vkui:Cell Header="Папка данных" Subtitle="{Binding LocalDataPath}">
            <vkui:Cell.Before>
              <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon24DoneOutline}"/>
            </vkui:Cell.Before>
          </vkui:Cell>
          <Button Classes="Tertiary" Click="ExportSettings_Click">
            <vkui:Cell Header="Экспорт в JSON" Subtitle="Сохранить клиентские настройки без токенов, E2E-ключей, черновиков и локальной истории.">
              <vkui:Cell.Before>
                <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon24ShareOutline}"/>
              </vkui:Cell.Before>
            </vkui:Cell>
          </Button>
          <Button Classes="Tertiary" Click="ImportSettings_Click">
            <vkui:Cell Header="Импорт из JSON" Subtitle="Применить настройки из backup-файла. Секреты и мусорные ключи игнорируются.">
              <vkui:Cell.Before>
                <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon16UploadOutline}"/>
              </vkui:Cell.Before>
            </vkui:Cell>
          </Button>
          <vkui:Cell Header="Локальная папка" Subtitle="{Binding LocalBackupDirectory}">
            <vkui:Cell.Before>
              <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon24DoneOutline}"/>
            </vkui:Cell.Before>
          </vkui:Cell>
          <Button Classes="Tertiary" Click="ChooseBackupFolder_Click">
            <vkui:Cell Header="Выбрать папку backup" Subtitle="Папка пользователя, куда Laney будет синхронизировать локальные данные аккаунта.">
              <vkui:Cell.Before>
                <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon24ShareOutline}"/>
              </vkui:Cell.Before>
            </vkui:Cell>
          </Button>
          <Button Classes="Tertiary" Click="SyncLocalBackup_Click">
            <vkui:Cell Header="Синхронизировать локальный backup" Subtitle="Настройки, offline snapshots, quick-actions, stickers, automation и индексы без токенов и cache-мусора.">
              <vkui:Cell.Before>
                <vkui:VKIcon Id="{x:Static vkui:VKIconNames.Icon16UploadOutline}"/>
              </vkui:Cell.Before>
            </vkui:Cell>
          </Button>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
